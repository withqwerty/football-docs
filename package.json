{
  "name": "football-docs",
  "version": "0.6.2",
  "description": "Searchable football data provider documentation for AI coding agents. Like Context7 for football data.",
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "mcpName": "io.github.withqwerty/football-docs",
  "bin": {
    "football-docs": "bin/serve.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "prebuild": "pnpm check",
    "check": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "ingest": "tsx src/ingest.ts",
    "crawl": "tsx src/crawl.ts",
    "discover": "tsx src/crawl.ts --discover",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "prepublishOnly": "pnpm build && pnpm ingest",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "keywords": [
    "football",
    "soccer",
    "opta",
    "statsbomb",
    "wyscout",
    "sportmonks",
    "mcp",
    "model-context-protocol",
    "analytics",
    "data"
  ],
  "author": {
    "name": "withqwerty",
    "url": "https://github.com/withqwerty"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withqwerty/football-docs.git"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.11.1",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.2",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  },
  "files": [
    "dist/",
    "bin/",
    "data/docs.db",
    "docs/",
    "providers.json"
  ]
}
